# JetsonZoom Configuration
# Copy this file to .env and update with your camera details

# Camera network settings
CAMERA_HOST=192.168.1.71
CAMERA_PORT_RTSP=554
CAMERA_PORT_ONVIF=80
CAMERA_USERNAME=admin
CAMERA_PASSWORD=L2bWoM8@

# Optional: Custom URLs (override above if set)
CAMERA_RTSP_URL=rtsp://admin:L2bWoM8@@192.168.1.71:554/stream
CAMERA_ONVIF_URL=http://192.168.1.71:80/onvif/device_service

# Streaming/display
# STREAM_BACKEND:
# - auto  : ưu tiên gst trên Jetson (Linux+aarch64), còn lại dùng OpenCV mặc định
# - opencv: cv2.VideoCapture(rtsp_url) (Windows thường dùng FFmpeg)
# - gst   : cv2.VideoCapture(GStreamer pipeline, CAP_GSTREAMER) (khuyến nghị trên Jetson)
STREAM_BACKEND=auto
DISPLAY_BACKEND=opencv
WINDOW_NAME=JetsonZoom
SOURCE_PICKER=always
LOG_LEVEL=DEBUG

TARGET_FPS=30
FRAME_QUEUE_SIZE=30
DISPLAY_WIDTH=1280
DISPLAY_HEIGHT=720

# Logging
LOG_LEVEL=INFO

# Source picker UI
# - auto  : nếu chạy trong terminal sẽ hiện menu, chạy trong IDE sẽ mở cửa sổ Source Picker
# - always: luôn mở Source Picker khi start (để nhập RTSP trong app)
# - never : không mở picker
SOURCE_PICKER=auto

# UI mode
# - qt     : giao diện desktop đầy đủ (khuyến nghị)
# - opencv : giao diện tối giản (OpenCV window)
UI=qt

# GStreamer pipeline (chỉ dùng khi STREAM_BACKEND=gst hoặc auto trên Jetson)
# Nếu camera dùng H.265 hoặc path khác, bạn nên override pipeline này.
# GST_PIPELINE_TEMPLATE=rtspsrc location={rtsp_url} latency=0 ! rtph265depay ! h265parse ! nvv4l2decoder ! nvvidconv ! video/x-raw,format=BGRx ! videoconvert ! video/x-raw,format=BGR ! appsink drop=true sync=false
